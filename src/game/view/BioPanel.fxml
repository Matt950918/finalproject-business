<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="game.controller.BioPanelController"
      spacing="25" alignment="TOP_CENTER"
      style="-fx-padding: 30; -fx-background-color: rgba(255, 255, 255, 0.45); -fx-background-radius: 20;"> <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffffff; -fx-background-radius: 15; -fx-padding: 15 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 5);">
    <VBox spacing="5">
        <Label text="🧬 遠東生物科技研發中心" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #333333;" />
        <Label text="CEO 臨床新藥開發控制台" style="-fx-font-size: 14px; -fx-text-fill: #777777;" />
    </VBox>
    <Region HBox.hgrow="ALWAYS" />
    <HBox spacing="10" alignment="CENTER">
        <Label fx:id="lblRnDStatus" text="🔬 研發效率：100%" style="-fx-background-color: #ebe9f4; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 15; -fx-font-weight: bold;" />
        <Label fx:id="lblSuccessBonusStatus" text="🎯 成功率加成：+0%" style="-fx-background-color: #c4dcfa; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 15; -fx-font-weight: bold;" />
    </HBox>
</HBox>

    <HBox spacing="25" VBox.vgrow="ALWAYS">

        <VBox spacing="20" HBox.hgrow="ALWAYS" style="-fx-background-color: #f7f7f7; -fx-background-radius: 15; -fx-padding: 25; -fx-border-color: #ebe9f4; -fx-border-width: 1.5;">
            <Label text="🧪 核心藥物臨床實驗進度" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;" />
            <Separator />

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="15" style="-fx-background-color: transparent;">

                    <VBox spacing="12" style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-padding: 18; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="💊 次世代抗癌特效藥 (Special)" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="研發成本: $500 萬" style="-fx-background-color: #e3d8f9; -fx-text-fill: #333333; -fx-padding: 4 10; -fx-background-radius: 10; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        </HBox>
                        <Label text="基礎研發成功率：40%。屬於高風險、高報酬項目，一旦三期臨床通過成功上市，將能為集團開創龐大專利變現流。" style="-fx-text-fill: #666666; -fx-font-size: 14px;" wrapText="true" />
                        <HBox alignment="CENTER_RIGHT">
                            <Button text="啟動臨床實驗 ➔" onAction="#handleResearchSpecial" style="-fx-background-color: #c4dcfa; -fx-text-fill: #333333; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 16;" />
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>

        <VBox spacing="18" prefWidth="380" style="-fx-background-color: #f7f7f7; -fx-background-radius: 15; -fx-padding: 25; -fx-border-color: #ebe9f4; -fx-border-width: 1.5;">
            <Label text="🌳 核心技術專利權升級" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;" />
            <Separator />

            <Label text="透過挹注資本升級實驗室設備，能永久改良後續所有新藥的臨床體質與生產收益。" style="-fx-text-fill: #777777; -fx-font-size: 13px;" wrapText="true" />

            <VBox spacing="12" VBox.vgrow="ALWAYS" alignment="TOP_CENTER">
                <Button text="🔬 升級 AI 模擬設備 (+5% 成功率)\n升級費用：$300 萬" onAction="#handleUpgradeRnD" maxWidth="1.7976931348623157E308" style="-fx-background-color: #b7e9ed; -fx-text-fill: #333333; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12; -fx-cursor: hand; -fx-text-alignment: center;" />

                <Button text="📢 投放跨國醫學期刊 (+10% 品牌權重)\n升級費用：$250 萬" onAction="#handleUpgradeBrand" maxWidth="1.7976931348623157E308" style="-fx-background-color: #fac9de; -fx-text-fill: #333333; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12; -fx-cursor: hand; -fx-text-alignment: center;" />

                <Button text="⚙️ 改良低溫製程技術 (-5% 研發成本)\n升級費用：$200 萬" onAction="#handleUpgradeEfficiency" maxWidth="1.7976931348623157E308" style="-fx-background-color: #e3d8f9; -fx-text-fill: #333333; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12; -fx-cursor: hand; -fx-text-alignment: center;" />
            </VBox>
        </VBox>

    </HBox>
</VBox>