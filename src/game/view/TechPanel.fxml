<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="game.controller.TechPanelController"
      spacing="25" alignment="TOP_CENTER"
      style="-fx-padding: 30; -fx-background-color: rgba(255, 255, 255, 0.45); -fx-background-radius: 20;">

    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffffff; -fx-background-radius: 15; -fx-padding: 15 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 5);">
        <VBox spacing="5">
            <Label text="💻 遠東 IC 設計與硬體供應鏈中心" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #333333;" />
            <Label text="掌握 EDA 授權、電路架構最佳化與晶圓代工良率" style="-fx-font-size: 14px; -fx-text-fill: #777777;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox spacing="10" alignment="CENTER">
            <Label fx:id="lblYield" text="⚙️ 當前代工良率：75%" style="-fx-background-color: #ebe9f4; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 15; -fx-font-weight: bold;" />
            <Label fx:id="lblCost" text="📉 單片晶圓成本：$1200" style="-fx-background-color: #c4dcfa; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 15; -fx-font-weight: bold;" />
        </HBox>
    </HBox>

    <HBox spacing="25" VBox.vgrow="ALWAYS">

        <VBox spacing="20" HBox.hgrow="ALWAYS" style="-fx-background-color: #f7f7f7; -fx-background-radius: 15; -fx-padding: 25; -fx-border-color: #ebe9f4; -fx-border-width: 1.5;">
            <Label text="📐 硬體架構與 EDA 授權管理" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;" />
            <Separator />

            <VBox spacing="15">
                <VBox spacing="12" style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-padding: 18; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="📜 頂級 EDA 軟體企業授權" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="授權費: $800 萬" style="-fx-background-color: #fac9de; -fx-text-fill: #333333; -fx-padding: 4 10; -fx-background-radius: 10; -fx-font-size: 13px; -fx-font-weight: bold;" />
                    </HBox>
                    <Label text="升級電子設計自動化工具，能大幅縮短電路模擬時間，降低 IC 佈局布線 (P&amp;R) 的邏輯錯誤率。" style="-fx-text-fill: #666666; -fx-font-size: 14px;" wrapText="true" />
                    <HBox alignment="CENTER_RIGHT">
                        <Button text="💳 支付授權費" onAction="#handleBuyEDA" style="-fx-background-color: #b7e9ed; -fx-text-fill: #333333; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 16;" />
                    </HBox>
                </VBox>
            </VBox>
        </VBox>

        <VBox spacing="18" prefWidth="400" style="-fx-background-color: #f7f7f7; -fx-background-radius: 15; -fx-padding: 25; -fx-border-color: #ebe9f4; -fx-border-width: 1.5;">
            <Label text="🤝 供應鏈合約談判桌" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;" />
            <Separator />

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox fx:id="partnerListContainer" spacing="12" style="-fx-background-color: transparent;" />
            </ScrollPane>
        </VBox>

    </HBox>
</VBox>