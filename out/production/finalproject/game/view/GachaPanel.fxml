<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="30.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="game.controller.GachaController"
      prefWidth="650.0" prefHeight="480.0"
      stylesheets="@global_theme.css"
      style="-fx-background-color: #F4F6F9;">
    <padding>
        <Insets top="35" right="50" bottom="35" left="50"/>
    </padding>

    <!-- 標題卡 -->
    <VBox alignment="CENTER" spacing="8.0"
          style="-fx-background-color: #ffffff;
                 -fx-background-radius: 15;
                 -fx-padding: 20 30;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 12, 0, 0, 4);">
        <Label text="🎲 機會命運中心"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #4E73DF;" />
        <Label text="消耗 $100.00 萬資金，抽取「機會」或「命運」"
               style="-fx-font-size: 14px; -fx-text-fill: #858796;" />
    </VBox>

    <!-- 結果顯示區 -->
    <VBox alignment="CENTER" prefHeight="150.0"
          style="-fx-background-color: #ffffff;
                 -fx-background-radius: 15;
                 -fx-border-color: #EBE9F4;
                 -fx-border-width: 1.5;
                 -fx-padding: 25 30;">
        <Label fx:id="lblResultDisplay"
               text="牌卡準備完畢，可抽取機會/命運..."
               wrapText="true" alignment="CENTER" textAlignment="CENTER"
               maxWidth="500"
               style="-fx-font-size: 15px; -fx-text-fill: #4E73DF; -fx-font-weight: bold;" />
    </VBox>

    <!-- 按鈕區：抽卡大、返回小，大小不對調 -->
    <VBox alignment="CENTER" spacing="14.0">

        <!-- 🎲 主要抽卡按鈕：大 -->
        <Button fx:id="btnGachaAction" onAction="#handleDraw"
                text="🎲 抽取機會命運 (花費 $100 萬)"
                style="-fx-background-color: #2E59D9;
                       -fx-text-fill: #FFFFFF;
                       -fx-font-size: 18px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 14;
                       -fx-padding: 16 50;
                       -fx-min-width: 320px;
                       -fx-cursor: hand;" />

        <!-- 🔙 返回按鈕：小 -->
        <Button onAction="#handleBack" text="🔙 返回公司經營"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #858796;
                       -fx-font-size: 13px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 10;
                       -fx-border-color: #D0D0D8;
                       -fx-border-width: 1.5;
                       -fx-border-radius: 10;
                       -fx-padding: 9 28;
                       -fx-min-width: 180px;
                       -fx-cursor: hand;" />
    </VBox>
</VBox>