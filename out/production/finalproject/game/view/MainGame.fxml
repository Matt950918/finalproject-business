<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="game.controller.MainGameController"
           stylesheets="@global_theme.css"
           prefWidth="1100" prefHeight="700"
           style="-fx-background-image: url('@../image/background.png'); -fx-background-size: cover; -fx-background-position: center;">

    <VBox fx:id="mainGameLayer" spacing="20" alignment="TOP_CENTER" style="-fx-padding: 20;">

        <HBox spacing="30" alignment="CENTER_LEFT" style="-fx-background-color: rgba(255,255,255,0.65); -fx-background-radius: 15; -fx-padding: 12 25;">
            <Label fx:id="lblDay" text="第 1 天" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #333333;" />
            <Label fx:id="lblTimer" text="剩餘時間：60 秒" style="-fx-font-size: 18px; -fx-text-fill: #E74A3B;" />
            <Button fx:id="btnCash" text="資金：$0" onAction="#showLedger"
                    style="-fx-background-color: transparent; -fx-text-fill: #2E59D9; -fx-font-size: 18px; -fx-cursor: hand; -fx-padding: 0;" />
            <Button fx:id="btnStockPrice" text="股價：$0.00" onAction="#showStockChart" style="-fx-background-color: transparent; -fx-text-fill: #1CC88A; -fx-font-size: 18px; -fx-cursor: hand; -fx-padding: 0;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="結束本日營業 ➔" onAction="#handleEndDay" style="-fx-background-color: #b7e9ed; -fx-text-fill: #333333; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 8 18;" />
        </HBox>

        <StackPane fx:id="industryContentArea" VBox.vgrow="ALWAYS" />

        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-padding: 10 25 0 25;">

            <Region HBox.hgrow="ALWAYS" />

            <HBox spacing="20" alignment="CENTER">
                <children>
                    <StackPane alignment="CENTER" maxWidth="-Infinity" maxHeight="-Infinity">
                        <children>
                            <Button fx:id="btnGacha" text="🎲 機會/命運" onAction="#handleLoadGacha" styleClass="switch-button" style="-fx-font-size: 16px; -fx-padding: 10 20;"/>
                            <javafx.scene.shape.Circle fx:id="gachaBadge" radius="5" fill="#ff3b30" stroke="WHITE" strokeWidth="1.5"
                                                       StackPane.alignment="TOP_RIGHT" translateX="3" translateY="-3" visible="false" />
                        </children>
                    </StackPane>

                    <Button fx:id="btnRanking" text="🏆 企業排行榜" onAction="#handleLoadRanking" styleClass="switch-button" style="-fx-font-size: 16px; -fx-padding: 10 20;"/>
                </children>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <Button text="↩ 返回主選單" onAction="#handleReturnToMainMenu"
                    style="-fx-background-color: #E74A3B; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 10 20;" />
        </HBox>

    </VBox>

    <VBox fx:id="newsOverlay" visible="false" alignment="CENTER" style="-fx-background-color: rgba(0, 0, 0, 0.6);">
        <VBox alignment="CENTER" spacing="25" style="-fx-background-color: rgba(255,255,255,0.95); -fx-background-radius: 20; -fx-padding: 40; -fx-max-width: 700;">
            <Label text="🚨 突發市場動態" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #E74A3B;" />
            <Separator prefWidth="500" />

            <Label fx:id="lblNewsTitle" text="讀取新聞中..."
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #333333;"
                   wrapText="true" textAlignment="CENTER" />

            <VBox fx:id="optionsBox" spacing="15" alignment="CENTER" />

            <Button text="忽視此消息 ⏩" onAction="#handleSkipDay" style="-fx-background-color: #DDDDDD; -fx-text-fill: #555555; -fx-font-size: 16px; -fx-background-radius: 10;" />
        </VBox>
    </VBox>

    <VBox fx:id="resultOverlay" visible="false" alignment="CENTER" style="-fx-background-color: rgba(0, 0, 0, 0.6);">
        <VBox alignment="CENTER" spacing="20" style="-fx-background-color: rgba(255,255,255,0.95); -fx-background-radius: 20; -fx-padding: 40; -fx-max-width: 600;">
            <Label fx:id="lblResultHeader" text="結算報告" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #5A5C69;" />
            <Separator prefWidth="400" />
            <Label fx:id="lblSettleReason" text="原因描述" style="-fx-font-size: 18px; -fx-text-fill: #333333;" wrapText="true" textAlignment="CENTER" />
            <Label fx:id="lblPriceChange" text="股價變動: +10.00" style="-fx-font-size: 22px; -fx-font-weight: bold;" />

            <Button text="進入下一天 ➔" onAction="#closeResultAndProceed" style="-fx-background-color: #4E73DF; -fx-text-fill: white; -fx-font-size: 18px; -fx-background-radius: 10;" />
        </VBox>
    </VBox>

</StackPane>